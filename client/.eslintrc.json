{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended",
        "plugin:react/jsx-runtime",
        "plugin:react-hooks/recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "rules": {
        "react/prop-types": "off"
    },
    "settings": {
        "react": {
            "version": "detect"
        }
    },
    "overrides": [
        {
            "files": ["cypress/**/*.js"],
            "env": {
                "mocha": true,
                "node": true
            },
            "globals": {
                "cy": true,
                "Cypress": true
            }
        },
        {
            "files": ["**/*.test.js", "**/*.test.jsx"],
            "env": {
                "jest": true
            }
        }
    ]
}